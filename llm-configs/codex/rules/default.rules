prefix_rule(pattern=["/bin/zsh", "-lc", "set -a; source .env.local; set +a; query=\"SELECT count() AS total_collected, countIf(has_audio_origin) AS origin_rows, countIf(has_audio_origin AND assessment_text IS NOT NULL AND assessment_text != \\'\\) AS origin_assessment_filled, countIf(has_audio_origin AND recognition_text IS NOT NULL AND recognition_text != \\'\\) AS origin_recognition_filled, countIf(has_audio_origin AND pronunciation_score IS NOT NULL) AS origin_score_filled, countIf(has_audio_processed AND NOT has_audio_origin) AS processed_only_rows, countIf(has_audio_processed AND NOT has_audio_origin AND assessment_text IS NOT NULL AND assessment_text != \\'\\) AS processed_only_assessment_filled FROM speakingmax.v_study_events_admin_v1 WHERE study_date >= toDate(\\'2026-05-23\\') AND study_date <= toDate(\\'2026-06-06\\') AND collection_status = \\'collected\\'\"; curl -sS --get \"$CLICKHOUSE_URL\" --data-urlencode \"user=$CLICKHOUSE_USER\" --data-urlencode \"password=$CLICKHOUSE_PASSWORD\" --data-urlencode \"database=$CLICKHOUSE_DATABASE\" --data-urlencode \"query=$query FORMAT TSVWithNames\""], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "set -a; source .env.local; set +a; query=\"SELECT count() AS total_collected, countIf(has_audio_origin) AS origin_rows, countIf(has_audio_origin AND isNotNull(assessment_text) AND length(assumeNotNull(assessment_text)) > 0) AS origin_assessment_filled, countIf(has_audio_origin AND isNotNull(recognition_text) AND length(assumeNotNull(recognition_text)) > 0) AS origin_recognition_filled, countIf(has_audio_origin AND isNotNull(pronunciation_score)) AS origin_score_filled, countIf(has_audio_processed AND NOT has_audio_origin) AS processed_only_rows, countIf(has_audio_processed AND NOT has_audio_origin AND isNotNull(assessment_text) AND length(assumeNotNull(assessment_text)) > 0) AS processed_only_assessment_filled FROM speakingmax.v_study_events_admin_v1 WHERE study_date >= {date_from:Date} AND study_date <= {date_to:Date} AND collection_status = {status:String}\"; curl -sS --get \"$CLICKHOUSE_URL\" --data-urlencode \"user=$CLICKHOUSE_USER\" --data-urlencode \"password=$CLICKHOUSE_PASSWORD\" --data-urlencode \"database=$CLICKHOUSE_DATABASE\" --data-urlencode \"param_date_from=2026-05-23\" --data-urlencode \"param_date_to=2026-06-06\" --data-urlencode \"param_status=collected\" --data-urlencode \"query=$query FORMAT TSVWithNames\""], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "set -a; source .env.local; set +a; query=\"SELECT device_type, study_mode, count() AS origin_rows, countIf(isNotNull(assessment_text) AND length(assumeNotNull(assessment_text)) > 0) AS assessment_filled, countIf(isNotNull(recognition_text) AND length(assumeNotNull(recognition_text)) > 0) AS recognition_filled, countIf(isNotNull(pronunciation_score)) AS score_filled FROM speakingmax.v_study_events_admin_v1 WHERE study_date >= {date_from:Date} AND study_date <= {date_to:Date} AND collection_status = {status:String} AND has_audio_origin GROUP BY device_type, study_mode ORDER BY origin_rows DESC LIMIT 20\"; curl -sS --get \"$CLICKHOUSE_URL\" --data-urlencode \"user=$CLICKHOUSE_USER\" --data-urlencode \"password=$CLICKHOUSE_PASSWORD\" --data-urlencode \"database=$CLICKHOUSE_DATABASE\" --data-urlencode \"param_date_from=2026-05-23\" --data-urlencode \"param_date_to=2026-06-06\" --data-urlencode \"param_status=collected\" --data-urlencode \"query=$query FORMAT TSVWithNames\""], decision="allow")
