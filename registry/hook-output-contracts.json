        },
        {
          "matcher": "Agent",
          "script": "hooks/agent-knowledge-remind.sh",
          "blocks_tool": false,
          "exit_contract": "exit-0-knowledge-reminder",
          "stdout": "conditional-knowledge-reminder",
          "stderr": "none",
          "status_message": null,
          "user_visible": true,
          "visible_channels": [
            "stdout"
          ],
          "migration_policy": "output-preserving-wrapper-candidate",
          "wrapper_requirements": [
            "stdin-replay-once-per-child",
            "per-child-timeout",
            "stdout-stderr-passthrough"
          ],
          "notes": "Reminds agent invocations about relevant knowledge files."
        },
        {
          "matcher": "Agent",
          "script": "hooks/gemma-review-prescan.sh",
          "blocks_tool": false,
          "exit_contract": "exit-0-review-prescan",
          "stdout": "conditional-review-prescan",
          "stderr": "none",
          "status_message": null,
          "user_visible": true,
          "visible_channels": [
            "stdout"
          ],
          "migration_policy": "output-preserving-wrapper-candidate",
          "wrapper_requirements": [
            "stdin-replay-once-per-child",
            "per-child-timeout",
            "stdout-stderr-passthrough",
            "adapter-telemetry"
          ],
          "notes": "Provides local ini review prescan context for reviewer agents."
        },
        {
          "matcher": "mcp__",
          "script": "hooks/mcp-deferred-guard.sh",
          "blocks_tool": true,
          "exit_contract": "exit-2-on-unloaded-deferred-mcp-tool",
          "stdout": "none",
          "stderr": "blocking-policy-message",
          "status_message": null,
          "user_visible": true,
          "visible_channels": [
            "stderr"
          ],
          "migration_policy": "keep-direct-until-mcp-router",
          "wrapper_requirements": [
            "stdin-replay-once-per-child",
            "per-child-timeout",
            "stdout-stderr-passthrough",
            "preserve-first-nonzero-exit",
            "stop-after-blocking-exit"
          ],
          "notes": "Blocks direct deferred MCP tool calls until ToolSearch has loaded the schema."
        },
        {
          "matcher": "AskUserQuestion",
