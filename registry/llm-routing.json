{
  "version": 2,
  "status": "active",
  "description": "Provider-neutral LLM routing policy. Claude, Codex, Gemini/agy, and local Gemma use the same task routes and handoff cache when possible.",
  "router": {
    "entrypoint": "scripts/llm-router.sh",
    "python_entrypoint": "scripts/llm-router.py",
    "adapter_entrypoint": "scripts/llm-call.sh",
    "handoff_path": "cache/llm-handoff/current.json",
    "health_path": "cache/llm-provider-health.json",
    "telemetry_path": "cache/llm-router-calls.jsonl",
    "parent_provider_env": "LLM_PARENT_PROVIDER",
    "active_provider_env": "LLM_ACTIVE_PROVIDER",
    "call_depth_env": "LLM_CALL_DEPTH",
    "max_call_depth": 2,
    "self_recursion_policy": "skip_parent_provider_by_default"
  },
  "tasks": {
    "default": {
      "strategy": "first_success",
      "providers": [
        "codex",
        "gemini",
        "gemma"
      ],
      "timeout_seconds": 90,
      "provider_timeouts_seconds": {
        "codex": 90,
        "gemini": 120,
        "gemma": 60
      },
      "privacy_tier": "external_ok",
      "purpose": "General fallback when the caller has no stronger task classification."
    },
    "scan": {
      "strategy": "first_success",
      "providers": [
        "gemini",
        "codex",
        "gemma"
      ],
      "timeout_seconds": 120,
      "provider_timeouts_seconds": {
        "gemini": 180,
        "codex": 120,
        "gemma": 60
      },
      "privacy_tier": "external_ok",
      "purpose": "Large-context structure scan, impact analysis, migration review."
    },
    "implement": {
      "strategy": "first_success",
      "providers": [
        "codex",
        "gemini"
      ],
      "timeout_seconds": 120,
      "provider_timeouts_seconds": {
        "codex": 150,
        "gemini": 120
      },
      "privacy_tier": "external_ok",
      "purpose": "Patch drafting or implementation alternative when the active provider needs handoff."
    },
    "review": {
      "strategy": "parallel_best_effort",
      "providers": [
        "codex",
        "gemini",
        "gemma"
      ],
      "timeout_seconds": 120,
      "provider_timeouts_seconds": {
        "codex": 120,
        "gemini": 180,
        "gemma": 60
      },
      "minimum_successes": 1,
      "max_parallel": 3,
      "privacy_tier": "external_ok",
      "purpose": "Multi-provider review or second opinion. Outputs are evidence, not automatic decisions."
    },
    "private": {
      "strategy": "first_success",
      "providers": [
        "gemma"
      ],
      "timeout_seconds": 60,
      "provider_timeouts_seconds": {
        "gemma": 60
      },
      "privacy_tier": "local_only",
      "purpose": "Sensitive or local-only question. External providers are intentionally excluded."
    },
    "rescue": {
      "strategy": "first_success",
      "providers": [
        "codex",
        "gemini",
        "gemma"
      ],
      "timeout_seconds": 150,
      "provider_timeouts_seconds": {
        "codex": 150,
        "gemini": 180,
        "gemma": 60
      },
      "privacy_tier": "external_ok",
      "purpose": "Recovery after repeated debug/test failure or active-provider quota exhaustion."
    },
    "summarize": {
      "strategy": "first_success",
      "providers": [
        "gemma",
        "codex",
        "gemini"
      ],
      "timeout_seconds": 60,
      "provider_timeouts_seconds": {
        "gemma": 60,
        "codex": 90,
        "gemini": 90
      },
      "privacy_tier": "local_preferred",
      "purpose": "Short summary, Korean draft, session note, or low-risk text transform."
    }
  },
  "providers": {
    "claude": {
      "role": "session_orchestrator_when_available",
      "entrypoints": [
        "Claude Code main session",
        "agents-src/*",
        "agents/moai/*"
      ],
      "responsibilities": [
        "intent interpretation when the active session is Claude",
        "result synthesis when Claude is the active orchestrator",
        "user-facing response when Claude is available"
      ],
      "privacy_tier": "workspace",
      "handoff_behavior": "writes and reads cache/llm-handoff/current.json through the shared router"
    },
    "gemini": {
      "role": "large_context_scanner",
      "entrypoints": [
        "GEMINI_CLI=agy",
        "Skill(ask-gemini)",
        "scripts/llm-call.sh gemini",
        "scripts/llm-router.sh scan",
        "scripts/gemini-wrapped.sh"
      ],
      "responsibilities": [
        "Phase 0 codebase scan",
        "dependency impact analysis",
        "broad review prescan",
        "final integration verification"
      ],
      "privacy_tier": "external",
      "cache_paths": [
        "cache/gemini/*-scan.md",
        "cache/gemini/*-deps.md",
        "cache/gemini/*-review-prescan.md"
      ]
    },
    "codex": {
      "role": "code_specialist_orchestrator_fallback",
      "entrypoints": [
        "codex exec",
        "scripts/llm-call.sh codex",
        "scripts/llm-router.sh implement",
        "scripts/llm-router.sh rescue",
        "codex:* plugin commands",
        "Skill(ask-codex)"
      ],
      "forbidden_entrypoints": [
        "mcp__codex-cli__*"
      ],
      "responsibilities": [
        "implementation alternative",
        "patch review",
        "adversarial review",
        "rescue after repeated debug/test failure",
        "primary continuation path when Claude quota is exhausted"
      ],
      "privacy_tier": "external"
    },
    "gemma": {
      "role": "local_private_second_opinion",
      "default_model": "gemma4:e4b",
      "availability": {
        "mode": "office_only_remote",
        "expected_offline_status": "expected_offline",
        "description": "Ollama runs on a Windows host at the office. It is expected to be unreachable from home or offsite networks."
      },
      "host_candidates": [
        "leonard.local:11434",
        "192.168.11.10:11434",
        "localhost:11434"
      ],
      "entrypoints": [
        "Ollama leonard.local:11434",
        "Skill(ask-ollama)",
        "scripts/llm-call.sh ini",
        "scripts/llm-router.sh private",
        "Gemma hooks"
      ],
      "responsibilities": [
        "private review prescan",
        "error summary",
        "commit draft",
        "session summary",
        "external-provider fallback for sensitive tasks"
      ],
      "privacy_tier": "local",
      "cache_paths": [
        "cache/gemma/*-review-prescan.md"
      ]
    },
    "antigravity": {
      "role": "manager_surface_and_gemini_cli_path",
      "entrypoints": [
        "agy",
        "antigravity-workspace.json"
      ],
      "responsibilities": [
        "Gemini-compatible large-context CLI calls",
        "workspace-level parallel dispatch surface"
      ],
      "privacy_tier": "external"
    }
  },
  "routing_principles": [
    "The active orchestrator synthesizes results; Claude is not assumed to be available.",
    "All provider calls from hooks/scripts should go through scripts/llm-router.sh or scripts/llm-call.sh.",
    "scripts/llm-router.sh owns task fallback, parent-provider skipping, and handoff cache updates.",
    "scripts/llm-call.sh owns provider execution and adapter telemetry.",
    "Gemini/agy handles broad context and integration checks.",
    "Codex is the preferred implementation and rescue fallback when Claude quota is exhausted.",
    "Gemma/Ollama is preferred for sensitive or local-only review.",
    "LLM outputs are evidence, not final authority."
  ]
}
